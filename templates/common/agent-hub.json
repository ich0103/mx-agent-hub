{
  "schemaVersion": 1,
  "name": "My Agent App",
  "description": "Short description for AX Agent Hub.",
  "version": "0.1.0",
  "entry": "app/index.html",
  "runtime": "static-html",
  "category": "SW 개발",
  "owner": "owner.id",
  "visibility": ["그룹"],
  "database": {
    "autoSplit": true,
    "include": ["data/**", "db/**", "datasets/**"],
    "exclude": ["app/config.json"],
    "largeHtmlThresholdMb": 5,
    "largeDataThresholdMb": 20,
    "databasePackageThresholdMb": 10,
    "maxCodePackageMb": 50
  },
  "hub": {
    "sandbox": true,
    "bridge": "postMessage",
    "minWidth": 360,
    "recommendedHeight": 760
  }
}
