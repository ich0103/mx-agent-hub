{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AX Agent Hub Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "name",
    "description",
    "version",
    "entry",
    "runtime"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "enum": ["static-html"]
    },
    "category": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "visibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "autoSplit": {
          "type": "boolean"
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "largeHtmlThresholdMb": {
          "type": "number",
          "minimum": 0
        },
        "largeDataThresholdMb": {
          "type": "number",
          "minimum": 0
        },
        "databasePackageThresholdMb": {
          "type": "number",
          "minimum": 0
        },
        "maxCodePackageMb": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "hub": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sandbox": {
          "type": "boolean"
        },
        "bridge": {
          "type": "string"
        },
        "minWidth": {
          "type": "integer"
        },
        "recommendedHeight": {
          "type": "integer"
        }
      }
    }
  }
}
